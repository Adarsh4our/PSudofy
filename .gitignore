# ─── Music & Downloads ────────────────────────────────────────────────────────
# Downloaded music files (can be huge)
music/
*.mp3
*.flac
*.m4a
*.opus
*.ogg
*.wav

# ─── Download Archives ────────────────────────────────────────────────────────
# Download archives (tracks what's been downloaded)
downloaded_spotify.txt
downloaded_yt.txt

# ─── Navidrome Data ───────────────────────────────────────────────────────────
# Navidrome database, cache, and config
data/
backups/*.zip

# ─── Application Logs ─────────────────────────────────────────────────────────
logs/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.egg

# ─── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.secret
secrets.txt

# ─── OS Clutter ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
